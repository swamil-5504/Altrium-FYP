# .env.example - Copy this file to .env and update values for your environment

# App
PROJECT_NAME=Altrium - Degree Verification System
VERSION=1.0.0
SUPERADMIN_EMAIL=admin@altrium.com
# Dev-only seed; must be rotated + pulled from a secret manager in production.
SUPERADMIN_PASSWORD=Altrium123!Dev
ENVIRONMENT=development

# API Configuration
API_V1_STR=/api/v1

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=altrium

# JWT
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (JSON array string). Must not include "*" in production.
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]

# Host header allowlist. Must not include "*" in production.
ALLOWED_HOSTS=["localhost","127.0.0.1","backend","emphasize-unthawed-cataract.ngrok-free.dev"]

# Redis (optional; can be empty)
REDIS_URL=

# Web3 integration (optional until contracts are deployed)
WEB3_PROVIDER_URI=
CONTRACT_SBT_ADDRESS=
CONTRACT_REGISTRY_ADDRESS=


# Demo / initial university admin seed (demo only)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_FULL_NAME=University Admin

PRIVATE_KEY=
REGISTRY_ADDRESS=
RPC_URL=

TELEGRAM_BOT_TOKEN=
WEBHOOK_HOST=
