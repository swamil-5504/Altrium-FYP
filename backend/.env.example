# .env.example - Copy this file to .env and update values for your environment

# App
PROJECT_NAME=Altrium - Degree Verification System
VERSION=1.0.0
ENVIRONMENT=development

# API Configuration
API_V1_STR=/api/v1

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=altrium

# JWT
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (JSON array string)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Redis (optional; can be empty)
REDIS_URL=

# Web3 integration (optional until contracts are deployed)
WEB3_PROVIDER_URI=https://rpc.sepolia.org
CONTRACT_SBT_ADDRESS=
CONTRACT_REGISTRY_ADDRESS=
PRIVATE_KEY=

# Demo / initial university admin seed (demo only)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_FULL_NAME=University Admin
