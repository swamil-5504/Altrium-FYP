# Foundry build artifacts
out/
cache/
lib/
# Forge script outputs
broadcast/

# Local environment / secrets
.env
.env.*
!.env.example

# OS / editor noise
.DS_Store
.vscode/

# Logs
*.log

# Optional: documentation build outputs (keep if you generate docs here)
docs/

# IMPORTANT:
# Do NOT ignore `lib/`, `foundry.lock`, or `.gitmodules`.
# Foundry installs dependencies into `lib/` (often as git submodules), and those
# should be committed for reproducible builds.