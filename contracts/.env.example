# Contracts env.example - Copy to .env to run Foundry scripts locally
# Do NOT commit your real .env (private keys).

# PRIVATE_KEY is read with vm.envUint("PRIVATE_KEY") in scripts,
# so it should be provided as a numeric value (decimal) or adjust scripts accordingly.
PRIVATE_KEY=

# RPC endpoint used by forge scripts (often passed as --rpc-url $RPC_URL)
RPC_URL=https://rpc.sepolia.org

