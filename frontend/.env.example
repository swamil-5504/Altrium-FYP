# Frontend env.example - used by Vite at build time
# Copy to .env and update values for your environment.

# Backend base URL used by the Axios wrapper (frontend appends /api/v1)
VITE_API_URL=http://localhost:8000

# Deployed AltriumRegistry address for the mint/verify UI
# (leave empty until you deploy contracts)
VITE_REGISTRY_ADDRESS=

